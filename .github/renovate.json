{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "matchPackageNames": ["@acme/**"],
      "enabled": false
    }
  ],
  "rangeStrategy": "bump",
  "automerge": true,
  "npm": {
    "managerFilePatterns": [
      "/(^|/)package\\.json$/",
      "/(^|/)package\\.json\\.hbs$/"
    ]
  }
}
